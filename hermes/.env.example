# Vidau OPEN LLM (required for Hermes chat)
VIDAU_API_KEY=tw-your-key-here
OPENAI_BASE_URL=https://open.vidau.ai/v1
OPENAI_API_KEY=tw-your-key-here

# ── Delivery (pick one; send_mail.py prefers SMTP when both exist) ──────────
#
# Option A — VidAU Messaging Email (recommended if already configured in desktop)
# Same keys as VidAU → Messaging → Email (also auto-read from
# %LOCALAPPDATA%/vidau/.env on Windows). No Resend key needed.
# EMAIL_ADDRESS=you@gmail.com
# EMAIL_PASSWORD=your-app-password
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_IMAP_HOST=imap.gmail.com
# EMAIL_IMAP_PORT=993
#
# Option B — Resend ESP (team / verified domain mail.vidau.ai)
# Get a key: https://resend.com/api-keys
RESEND_API_KEY=

# Optional: project root override (default = repo root via hermes/run.sh)
# EMAIL_AGENT_ROOT=
