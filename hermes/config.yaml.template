# email_demo isolated Hermes config (generated by install.sh)
# HERMES_HOME = __PROJECT_ROOT__/.hermes

skills:
  external_dirs:
    - "__PROJECT_ROOT__/skills"
  # Bundled himalaya steers NL "发送邮件" toward SMTP — disable in this profile.
  disabled:
    - himalaya
  config:
    email-demo:
      project_root: "__PROJECT_ROOT__"
      default_goal: "promotional"
      esp: "resend"

# Force NL email intents onto SEND path; block SMTP improvisation.
# Scripts live at $HERMES_HOME/agent-hooks/ (copied by hermes/run.sh).
hooks_auto_accept: true
hooks:
  pre_llm_call:
    - command: "__PROJECT_ROOT__/.hermes/agent-hooks/inject-email-routing.sh"
      timeout: 10
  pre_tool_call:
    - matcher: "execute_code|terminal|mcp_resend_send_email|mcp_resend_send_batch"
      command: "__PROJECT_ROOT__/.hermes/agent-hooks/block-smtp.sh"
      timeout: 5

model:
  provider: custom
  default: gpt-4o-mini
  base_url: https://open.vidau.ai/v1
  api_mode: chat_completions

mcp_servers:
  firecrawl:
    url: "https://mcp.firecrawl.dev/v2/mcp"
    enabled: false

  resend:
    url: "https://mcp.resend.com"
    headers:
      Authorization: "Bearer ${RESEND_API_KEY}"
    enabled: false
    # After RESEND_API_KEY in .hermes/.env: bash hermes/enable-resend.sh
    tools:
      exclude: ["broadcast-send"]  # deliberate safety — use resend.py CLI for broadcasts
